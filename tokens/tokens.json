{
    "color": {
        "teal": {
            "50":  { "$type": "color", "$value": "#F0FDFA" },
            "100": { "$type": "color", "$value": "#CCFBF1" },
            "300": { "$type": "color", "$value": "#5EEAD4" },
            "500": { "$type": "color", "$value": "#14B8A6" },
            "700": { "$type": "color", "$value": "#0F766E" }
        },
        "slate": {
            "50":  { "$type": "color", "$value": "#F8FAFC" },
            "100": { "$type": "color", "$value": "#F1F5F9" },
            "200": { "$type": "color", "$value": "#E2E8F0" },
            "300": { "$type": "color", "$value": "#CBD5E1" },
            "400": { "$type": "color", "$value": "#94A3B8" },
            "500": { "$type": "color", "$value": "#64748B" },
            "600": { "$type": "color", "$value": "#475569" },
            "700": { "$type": "color", "$value": "#334155" },
            "800": { "$type": "color", "$value": "#1E293B" },
            "850": { "$type": "color", "$value": "#162032" },
            "900": { "$type": "color", "$value": "#0F172A" },
            "950": { "$type": "color", "$value": "#0B1120" }
        },
        "emerald": {
            "50":  { "$type": "color", "$value": "#ECFDF5" },
            "100": { "$type": "color", "$value": "#D1FAE5" },
            "300": { "$type": "color", "$value": "#6EE7B7" },
            "500": { "$type": "color", "$value": "#10B981" },
            "700": { "$type": "color", "$value": "#047857" }
        },
        "rose": {
            "50":  { "$type": "color", "$value": "#FFF1F2" },
            "100": { "$type": "color", "$value": "#FFE4E6" },
            "300": { "$type": "color", "$value": "#FDA4AF" },
            "500": { "$type": "color", "$value": "#F43F5E" },
            "700": { "$type": "color", "$value": "#BE123C" }
        },
        "amber": {
            "50":  { "$type": "color", "$value": "#FFFBEB" },
            "100": { "$type": "color", "$value": "#FEF3C7" },
            "300": { "$type": "color", "$value": "#FCD34D" },
            "500": { "$type": "color", "$value": "#F59E0B" },
            "700": { "$type": "color", "$value": "#B45309" }
        },
        "white": { "$type": "color", "$value": "#FFFFFF" },
        "black": { "$type": "color", "$value": "#000000" }
    },
    "font": {
        "family": {
            "display": { "$type": "fontFamilies", "$value": "'DM Sans', sans-serif" },
            "body":    { "$type": "fontFamilies", "$value": "'DM Sans', sans-serif" },
            "mono":    { "$type": "fontFamilies", "$value": "'JetBrains Mono', monospace" }
        },
        "size": {
            "xs":   { "$type": "fontSizes", "$value": "0.75rem" },
            "sm":   { "$type": "fontSizes", "$value": "0.875rem" },
            "base": { "$type": "fontSizes", "$value": "1rem" },
            "lg":   { "$type": "fontSizes", "$value": "1.25rem" },
            "xl":   { "$type": "fontSizes", "$value": "1.5rem" },
            "2xl":  { "$type": "fontSizes", "$value": "2rem" }
        },
        "weight": {
            "normal":   { "$type": "fontWeights", "$value": "400" },
            "medium":   { "$type": "fontWeights", "$value": "500" },
            "semibold": { "$type": "fontWeights", "$value": "600" },
            "bold":     { "$type": "fontWeights", "$value": "700" }
        },
        "lineHeight": {
            "tight":   { "$type": "lineHeights", "$value": "1.3" },
            "normal":  { "$type": "lineHeights", "$value": "1.5" },
            "relaxed": { "$type": "lineHeights", "$value": "1.7" }
        }
    },
    "spacing": {
        "0":  { "$type": "dimension", "$value": "0" },
        "1":  { "$type": "dimension", "$value": "0.25rem" },
        "2":  { "$type": "dimension", "$value": "0.5rem" },
        "3":  { "$type": "dimension", "$value": "0.75rem" },
        "4":  { "$type": "dimension", "$value": "1rem" },
        "5":  { "$type": "dimension", "$value": "1.25rem" },
        "6":  { "$type": "dimension", "$value": "1.5rem" },
        "8":  { "$type": "dimension", "$value": "2rem" },
        "10": { "$type": "dimension", "$value": "2.5rem" },
        "12": { "$type": "dimension", "$value": "3rem" },
        "16": { "$type": "dimension", "$value": "4rem" },
        "20": { "$type": "dimension", "$value": "5rem" },
        "24": { "$type": "dimension", "$value": "6rem" }
    },
    "radius": {
        "none": { "$type": "dimension", "$value": "0" },
        "sm":   { "$type": "dimension", "$value": "4px" },
        "base": { "$type": "dimension", "$value": "6px" },
        "md":   { "$type": "dimension", "$value": "8px" },
        "lg":   { "$type": "dimension", "$value": "12px" }
    },
    "shadow": {
        "xs":   { "$type": "boxShadow", "$value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)" },
        "sm":   { "$type": "boxShadow", "$value": "0 1px 3px 0 rgba(0, 0, 0, 0.08), 0 1px 2px -1px rgba(0, 0, 0, 0.04)" },
        "base": { "$type": "boxShadow", "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.08), 0 2px 4px -2px rgba(0, 0, 0, 0.04)" },
        "md":   { "$type": "boxShadow", "$value": "0 8px 16px -4px rgba(0, 0, 0, 0.10), 0 4px 6px -2px rgba(0, 0, 0, 0.04)" },
        "lg":   { "$type": "boxShadow", "$value": "0 20px 25px -5px rgba(0, 0, 0, 0.10), 0 8px 10px -6px rgba(0, 0, 0, 0.04)" }
    },
    "transition": {
        "fast": { "$type": "dimension", "$value": "120ms" },
        "base": { "$type": "dimension", "$value": "200ms" },
        "slow": { "$type": "dimension", "$value": "320ms" }
    },
    "screen": {
        "mobile":  { "$type": "dimension", "$value": "768px" },
        "desktop": { "$type": "dimension", "$value": "1200px" }
    },
    "z-index": {
        "dropdown":       { "$type": "number", "$value": 1000 },
        "sticky":         { "$type": "number", "$value": 1020 },
        "fixed":          { "$type": "number", "$value": 1030 },
        "modal-backdrop": { "$type": "number", "$value": 1040 },
        "modal":          { "$type": "number", "$value": 1050 },
        "tooltip":        { "$type": "number", "$value": 1070 }
    },
    "semantic": {
        "bg": {
            "canvas":         { "$type": "color", "$value": "#F4F7FB" },
            "surface":        { "$type": "color", "$value": "{color.white}" },
            "surfaceRaised":  { "$type": "color", "$value": "#FCFDFE" },
            "surfaceOverlay": { "$type": "color", "$value": "rgba(0, 0, 0, 0.40)" },
            "muted":          { "$type": "color", "$value": "#EEF3F8" },
            "subtle":         { "$type": "color", "$value": "#E3EAF2" },
            "inverse":        { "$type": "color", "$value": "{color.slate.900}" },
            "input":          { "$type": "color", "$value": "{color.white}" },
            "recessed":       { "$type": "color", "$value": "#EDF2F7" },
            "hover":          { "$type": "color", "$value": "rgba(15, 23, 42, 0.04)" },
            "elevated":       { "$type": "color", "$value": "{color.white}" },
            "footer":         { "$type": "color", "$value": "{color.slate.950}" }
        },
        "text": {
            "primary":         { "$type": "color", "$value": "{color.slate.900}" },
            "secondary":       { "$type": "color", "$value": "{color.slate.600}" },
            "tertiary":        { "$type": "color", "$value": "{color.slate.500}" },
            "disabled":        { "$type": "color", "$value": "{color.slate.400}" },
            "inverse":         { "$type": "color", "$value": "{color.white}" },
            "link":            { "$type": "color", "$value": "{color.teal.700}" },
            "onAction":        { "$type": "color", "$value": "{color.white}" },
            "footer":          { "$type": "color", "$value": "{color.white}" },
            "footerMuted":     { "$type": "color", "$value": "{color.slate.300}" },
            "footerLink":      { "$type": "color", "$value": "{color.slate.300}" },
            "footerLinkHover": { "$type": "color", "$value": "{color.white}" }
        },
        "border": {
            "default": { "$type": "color", "$value": "{color.slate.200}" },
            "subtle":  { "$type": "color", "$value": "#E9EEF5" },
            "strong":  { "$type": "color", "$value": "{color.slate.300}" },
            "focus":   { "$type": "color", "$value": "{color.teal.500}" }
        },
        "action": {
            "primary":        { "$type": "color", "$value": "{color.teal.500}" },
            "primaryHover":   { "$type": "color", "$value": "{color.teal.700}" },
            "secondary":      { "$type": "color", "$value": "#F2F6FA" },
            "secondaryHover": { "$type": "color", "$value": "#E6EDF5" },
            "danger":         { "$type": "color", "$value": "{color.rose.500}" },
            "dangerHover":    { "$type": "color", "$value": "{color.rose.700}" },
            "accent":         { "$type": "color", "$value": "{color.teal.500}" },
            "accentMuted":    { "$type": "color", "$value": "rgba(20, 184, 166, 0.10)" }
        },
        "status": {
            "positive":      { "$type": "color", "$value": "{color.emerald.500}" },
            "positiveMuted": { "$type": "color", "$value": "{color.emerald.50}" },
            "positiveText":  { "$type": "color", "$value": "{color.emerald.700}" },
            "negative":      { "$type": "color", "$value": "{color.rose.500}" },
            "negativeMuted": { "$type": "color", "$value": "{color.rose.50}" },
            "negativeText":  { "$type": "color", "$value": "{color.rose.700}" },
            "warning":       { "$type": "color", "$value": "{color.amber.500}" },
            "warningMuted":  { "$type": "color", "$value": "{color.amber.50}" },
            "warningText":   { "$type": "color", "$value": "{color.amber.700}" },
            "info":          { "$type": "color", "$value": "{color.teal.500}" },
            "infoMuted":     { "$type": "color", "$value": "{color.teal.50}" },
            "infoText":      { "$type": "color", "$value": "{color.teal.700}" }
        },
        "price": {
            "up":        { "$type": "color", "$value": "{color.emerald.700}" },
            "upMuted":   { "$type": "color", "$value": "{color.emerald.50}" },
            "down":      { "$type": "color", "$value": "{color.rose.700}" },
            "downMuted": { "$type": "color", "$value": "{color.rose.50}" }
        }
    },
    "component": {
        "button": {
            "primaryBg":        { "$type": "color", "$value": "{semantic.action.primary}" },
            "primaryBgHover":   { "$type": "color", "$value": "{semantic.action.primaryHover}" },
            "primaryText":      { "$type": "color", "$value": "{semantic.text.onAction}" },
            "secondaryBg":      { "$type": "color", "$value": "{semantic.action.secondary}" },
            "secondaryBgHover": { "$type": "color", "$value": "{semantic.action.secondaryHover}" },
            "secondaryText":    { "$type": "color", "$value": "{semantic.text.primary}" },
            "dangerBg":         { "$type": "color", "$value": "{semantic.action.danger}" },
            "dangerBgHover":    { "$type": "color", "$value": "{semantic.action.dangerHover}" },
            "dangerText":       { "$type": "color", "$value": "{semantic.text.onAction}" },
            "ghostText":        { "$type": "color", "$value": "{semantic.text.secondary}" },
            "ghostTextHover":   { "$type": "color", "$value": "{semantic.text.primary}" }
        },
        "input": {
            "bg":          { "$type": "color", "$value": "{semantic.bg.input}" },
            "text":        { "$type": "color", "$value": "{semantic.text.primary}" },
            "placeholder": { "$type": "color", "$value": "{semantic.text.tertiary}" },
            "border":      { "$type": "color", "$value": "{semantic.border.default}" },
            "borderFocus": { "$type": "color", "$value": "{semantic.border.focus}" },
            "borderError": { "$type": "color", "$value": "{semantic.status.negative}" },
            "labelText":   { "$type": "color", "$value": "{semantic.text.secondary}" },
            "helpText":    { "$type": "color", "$value": "{semantic.text.tertiary}" },
            "errorText":   { "$type": "color", "$value": "{semantic.status.negative}" }
        },
        "card": {
            "bg":         { "$type": "color", "$value": "{semantic.bg.surface}" },
            "border":     { "$type": "color", "$value": "{semantic.border.subtle}" },
            "headerText": { "$type": "color", "$value": "{semantic.text.primary}" },
            "bodyText":   { "$type": "color", "$value": "{semantic.text.secondary}" }
        },
        "nav": {
            "bg":             { "$type": "color", "$value": "{semantic.bg.surface}" },
            "itemText":       { "$type": "color", "$value": "{semantic.text.secondary}" },
            "itemTextHover":  { "$type": "color", "$value": "{semantic.text.primary}" },
            "itemTextActive": { "$type": "color", "$value": "{semantic.action.accent}" },
            "itemBgActive":   { "$type": "color", "$value": "{semantic.action.accentMuted}" },
            "indicator":      { "$type": "color", "$value": "{semantic.action.accent}" },
            "sectionText":    { "$type": "color", "$value": "{semantic.text.tertiary}" }
        },
        "header": {
            "bg":       { "$type": "color", "$value": "{semantic.bg.surface}" },
            "border":   { "$type": "color", "$value": "{semantic.border.subtle}" },
            "text":     { "$type": "color", "$value": "{semantic.text.primary}" },
            "logoText": { "$type": "color", "$value": "{semantic.action.accent}" }
        },
        "table": {
            "headerBg":   { "$type": "color", "$value": "{semantic.bg.recessed}" },
            "headerText": { "$type": "color", "$value": "{semantic.text.secondary}" },
            "rowBg":      { "$type": "color", "$value": "{semantic.bg.surface}" },
            "rowBgHover": { "$type": "color", "$value": "{semantic.bg.hover}" },
            "rowText":    { "$type": "color", "$value": "{semantic.text.primary}" },
            "border":     { "$type": "color", "$value": "{semantic.border.subtle}" }
        },
        "modal": {
            "overlayBg":  { "$type": "color", "$value": "{semantic.bg.surfaceOverlay}" },
            "bg":         { "$type": "color", "$value": "{semantic.bg.elevated}" },
            "headerText": { "$type": "color", "$value": "{semantic.text.primary}" },
            "bodyText":   { "$type": "color", "$value": "{semantic.text.secondary}" }
        },
        "badge": {
            "positiveBg":   { "$type": "color", "$value": "{semantic.status.positiveMuted}" },
            "positiveText": { "$type": "color", "$value": "{semantic.status.positiveText}" },
            "negativeBg":   { "$type": "color", "$value": "{semantic.status.negativeMuted}" },
            "negativeText": { "$type": "color", "$value": "{semantic.status.negativeText}" },
            "warningBg":    { "$type": "color", "$value": "{semantic.status.warningMuted}" },
            "warningText":  { "$type": "color", "$value": "{semantic.status.warningText}" },
            "infoBg":       { "$type": "color", "$value": "{semantic.status.infoMuted}" },
            "infoText":     { "$type": "color", "$value": "{semantic.status.infoText}" },
            "defaultBg":    { "$type": "color", "$value": "{semantic.bg.hover}" },
            "defaultText":  { "$type": "color", "$value": "{semantic.text.secondary}" }
        },
        "footer": {
            "bg":        { "$type": "color", "$value": "{semantic.bg.footer}" },
            "text":      { "$type": "color", "$value": "{semantic.text.footer}" },
            "textMuted": { "$type": "color", "$value": "{semantic.text.footerMuted}" },
            "link":      { "$type": "color", "$value": "{semantic.text.footerLink}" },
            "linkHover": { "$type": "color", "$value": "{semantic.text.footerLinkHover}" }
        },
        "exchange": {
            "panelBg":      { "$type": "color", "$value": "{semantic.bg.surface}" },
            "rateUpText":   { "$type": "color", "$value": "{semantic.price.up}" },
            "rateDownText": { "$type": "color", "$value": "{semantic.price.down}" },
            "rateUpBg":     { "$type": "color", "$value": "{semantic.price.upMuted}" },
            "rateDownBg":   { "$type": "color", "$value": "{semantic.price.downMuted}" }
        },
        "spinner": {
            "track":     { "$type": "color", "$value": "{semantic.border.subtle}" },
            "indicator": { "$type": "color", "$value": "{semantic.action.accent}" }
        }
    }
}

